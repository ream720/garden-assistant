{
  "name": "grospace",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest --no-watch",
    "test:rules": "npm run test:rules:phase2",
    "test:rules:phase1": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8081 npx -y firebase-tools@latest emulators:exec --config firebase.rules-test.json --only firestore \"node scripts/test-firestore-rules-phase1.mjs\"",
    "test:rules:phase2": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8081 npx -y firebase-tools@latest emulators:exec --config firebase.rules-test.json --only firestore \"node scripts/test-firestore-rules-phase2.mjs\"",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test:e2e": "PW_USE_FIREBASE_EMULATOR=true playwright test",
    "test:e2e:cloud": "playwright test",
    "test:e2e:cloud:headed": "playwright test --headed",
    "test:e2e:cloud:ui": "playwright test --ui",
    "test:e2e:emulator": "PW_USE_FIREBASE_EMULATOR=true playwright test",
    "test:e2e:emulator:headed": "PW_USE_FIREBASE_EMULATOR=true playwright test --headed",
    "test:e2e:emulator:ui": "PW_USE_FIREBASE_EMULATOR=true playwright test --ui",
    "test:e2e:ui": "PW_USE_FIREBASE_EMULATOR=true playwright test --ui",
    "test:e2e:headed": "PW_USE_FIREBASE_EMULATOR=true playwright test --headed",
    "test:e2e:seed-smoke": "PW_RUN_SEED_SMOKE=true playwright test e2e/seed-account-smoke.spec.ts",
    "emulators:start:test": "node scripts/start-firebase-emulators.mjs",
    "emulators:seed:test": "node scripts/seed-firebase-emulator.mjs",
    "test:e2e:bootstrap": "node scripts/seed-firebase-emulator.mjs",
    "seed:account": "node scripts/seed-firebase-account.mjs",
    "seed:account:dry": "node scripts/seed-firebase-account.mjs --dry-run",
    "backfill:auth-users": "node scripts/backfill-auth-users.mjs",
    "backfill:auth-users:dry": "node scripts/backfill-auth-users.mjs --dry-run",
    "migrate:firestore:user-subcollections": "node scripts/migrate-firestore-user-subcollections.mjs",
    "migrate:firestore:user-subcollections:dry": "node scripts/migrate-firestore-user-subcollections.mjs --dry-run",
    "migrate:firestore:user-subcollections:verify": "node scripts/migrate-firestore-user-subcollections.mjs --verify-only",
    "migrate:firestore:user-subcollections:finalize": "node scripts/migrate-firestore-user-subcollections.mjs --finalize",
    "migrate:firestore:user-subcollections:finalize:dry": "node scripts/migrate-firestore-user-subcollections.mjs --finalize --dry-run"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@react-router/node": "^7.9.2",
    "@react-router/serve": "^7.9.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.3.0",
    "isbot": "^5.1.31",
    "lucide-react": "^0.544.0",
    "react": "^19.1.1",
    "react-day-picker": "^9.11.0",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.63.0",
    "react-router": "^7.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.11",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.58.2",
    "@react-router/dev": "^7.9.2",
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/ui": "^3.2.4",
    "dotenv": "^17.3.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "firebase-admin": "^13.0.1",
    "jsdom": "^27.0.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
