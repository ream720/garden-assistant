# Firebase Configuration
# Get these values from your Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=grospace.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=grospace
VITE_FIREBASE_STORAGE_BUCKET=grospace.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Optional: local Firebase emulator wiring
VITE_USE_FIREBASE_EMULATORS=false
VITE_FIRESTORE_DATA_MODEL_MODE=dual
VITE_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
VITE_FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
VITE_FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# E2E credential defaults (used by Playwright global setup/login helper)
VITE_FIREBASE_LOGIN_USER=e2e@grospace.test
VITE_FIREBASE_LOGIN_PW=Password123!
PW_E2E_EMAIL=e2e@grospace.test
PW_E2E_PASSWORD=Password123!
