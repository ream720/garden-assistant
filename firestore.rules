rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users can read and write their own user document
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Phase 1 (dual model): user-owned subcollections with transitional userId field.
      match /spaces/{spaceId} {
        allow list: if isOwner(userId);
        allow get, delete: if isOwner(userId) && resource.data.userId == userId;
        allow update: if isOwner(userId)
          && resource.data.userId == userId
          && request.resource.data.userId == userId;
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
      }

      match /plants/{plantId} {
        allow list: if isOwner(userId);
        allow get, delete: if isOwner(userId) && resource.data.userId == userId;
        allow update: if isOwner(userId)
          && resource.data.userId == userId
          && request.resource.data.userId == userId;
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
      }

      match /notes/{noteId} {
        allow list: if isOwner(userId);
        allow get, delete: if isOwner(userId) && resource.data.userId == userId;
        allow update: if isOwner(userId)
          && resource.data.userId == userId
          && request.resource.data.userId == userId;
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
      }

      match /tasks/{taskId} {
        allow list: if isOwner(userId);
        allow get, delete: if isOwner(userId) && resource.data.userId == userId;
        allow update: if isOwner(userId)
          && resource.data.userId == userId
          && request.resource.data.userId == userId;
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
      }
    }

    // Legacy top-level collections retained during phase-1 dual model rollout.
    match /spaces/{spaceId} {
      allow read, delete: if isAuthenticated() && isOwner(resource.data.userId);
      allow update: if isAuthenticated()
        && isOwner(resource.data.userId)
        && isOwner(request.resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
    }
    
    // Users can read and write their own plants
    match /plants/{plantId} {
      allow read, delete: if isAuthenticated() && isOwner(resource.data.userId);
      allow update: if isAuthenticated()
        && isOwner(resource.data.userId)
        && isOwner(request.resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
    }
    
    // Users can read and write their own notes
    match /notes/{noteId} {
      allow read, delete: if isAuthenticated() && isOwner(resource.data.userId);
      allow update: if isAuthenticated()
        && isOwner(resource.data.userId)
        && isOwner(request.resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
    }
    
    // Users can read and write their own tasks
    match /tasks/{taskId} {
      allow read, delete: if isAuthenticated() && isOwner(resource.data.userId);
      allow update: if isAuthenticated()
        && isOwner(resource.data.userId)
        && isOwner(request.resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
    }
  }
}
